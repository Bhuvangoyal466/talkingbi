# ─────────────────────────────────────────────────────────
# TalkingBI — Environment Configuration Example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────
# Options: openrouter | groq | ollama
LLM_PROVIDER=openrouter

# ── OpenRouter (recommended — free tier available) ───────
# Sign up at https://openrouter.ai and create an API key.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model names (OpenRouter format: provider/model-id)
# Free models that work well (check openrouter.ai/models for the latest list):
PRIMARY_MODEL=nvidia/nemotron-3-super-120b-a12b:free
CODE_MODEL=minimax/minimax-m2.5:free

# ── Groq (optional cloud fallback) ───────────────────────
# Sign up at https://console.groq.com/
GROQ_API_KEY=

# ── Ollama (optional local fallback) ─────────────────────
# Only needed if LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings (always local) ────────────────────────────
# Requires: pip install sentence-transformers
EMBED_MODEL=all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Application ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_SESSIONS=50

# ── Voice Agent ──────────────────────────────────────────
VOICE_USE_LOCAL_TRANSCRIPTION=false
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_INITIAL_PROMPT=Business intelligence analysis. Revenue, EBITDA, gross margin, net profit, CAC, LTV, churn rate.
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
VOICE_MAX_SPOKEN_WORDS=150

# ── Performance tuning (Fix 6) ───────────────────────────
# MAX_EXPLORATION_STEPS — MCTS triplet target for DB exploration.
#   Lower  = faster first upload, less schema coverage.
#   Higher = richer KB, more LLM calls during upload.
#   Default 10 cuts ~50% of LLM calls vs the original 20/30.
#   Raise to 20-30 only for databases with many complex tables.
MAX_EXPLORATION_STEPS=10

# N_INSIGHT_QUESTIONS — questions generated per insight run.
#   Lower  = faster insights, less breadth.
#   Higher = broader coverage, more LLM calls.
#   Default 4 cuts 33% of calls vs the original 6.
#   Raise to 6 if users need more exhaustive insight discovery.
N_INSIGHT_QUESTIONS=4
